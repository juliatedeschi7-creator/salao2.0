'use client'
import { useEffect, useState, useRef } from 'react'
import { supabase } from '@/lib/supabase'
import { useAuth } from '@/lib/hooks/useAuth'
import { useRouter, useParams } from 'next/navigation'
import { ArrowLeft, Camera, Plus, Trash2, Eye, EyeOff, ChevronDown } from 'lucide-react'

const CATEGORIAS: Record<string, string[]> = {
  'Pele': ['Melasma', 'Acne', 'Rejuvenescimento', 'Limpeza de Pele', 'Hidratação', 'Manchas', 'Outros'],
  'Unhas': ['Manicure', 'Pedicure', 'Gel', 'Fibra', 'Nail Art', 'Outros'],
  'Cabelo': ['Coloração', 'Corte', 'Tratamento', 'Escova', 'Progressiva', 'Outros'],
  'Estética': ['Depilação', 'Massagem', 'Drenagem', 'Brow Design', 'Cílios', 'Outros'],
}

function FotoUpload({ label, preview, onChange, cor }: {
  label: string; preview: string | null; onChange: (f: File) => void; cor: string
}) {
  const ref = useRef<HTMLInputElement>(null)
  return (
    <div className="flex flex-col gap-1.5">
      <label className="text-xs font-bold text-gray-500 uppercase tracking-wide">{label}</label>
      <button onClick={() => ref.current?.click()}
        className="w-full h-44 rounded-2xl flex flex-col items-center justify-center gap-2 border-2 border-dashed overflow-hidden"
        style={{ borderColor: preview ? 'transparent' : `${cor}40`, backgroundColor: preview ? 'transparent' : `${cor}08` }}>
        {preview
          ? <img src={preview} alt={label} className="w-full h-full object-cover" />
          : <>
              <Camera size={28} style={{ color: cor }} />
              <span className="text-sm font-medium" style={{ color: cor }}>Toque para adicionar</span>
            </>}
      </button>
      <input ref={ref} type="file" accept="image/*" capture="environment" className="hidden"
        onChange={e => e.target.files?.[0] && onChange(e.target.files[0])} />
    </div>
  )
}

export default function EvolucaoDonoPg() {
  const { profile, loading } = useAuth()
  const router = useRouter()
  const params = useParams()
  const clienteId = params.clienteId as string

  const [salao, setSalao] = useState<any>(null)
  const [cliente, setCliente] = useState<any>(null)
  const [registros, setRegistros] = useState<any[]>([])
  const [modal, setModal] = useState(false)
  const [categoria, setCategoria] = useState('Pele')
  const [subcategoria, setSubcategoria] = useState('')
  const [servicoNome, setServicoNome] = useState('')
  const [observacoes, setObservacoes] = useState('')
  const [fileAntes, setFileAntes] = useState<File | null>(null)
  const [fileDepois, setFileDepois] = useState<File | null>(null)
  const [prevAntes, setPrevAntes] = useState<string | null>(null)
  const [prevDepois, setPrevDepois] = useState<string | null>(null)
  const [salvando, setSalvando] = useState(false)
  const [filtroCategoria, setFiltroCategoria] = useState('Todos')

  useEffect(() => {
    if (!loading && profile?.salao_id) carregarDados()
  }, [loading])

  async function carregarDados() {
    const { data: sal } = await supabase.from('saloes').select('*').eq('id', profile!.salao_id!).single()
    setSalao(sal)
    const { data: cli } = await supabase.from('clientes').select('*').eq('id', clienteId).single()
    setCliente(cli)
    await carregarRegistros()
  }

  async function carregarRegistros() {
    const { data } = await supabase.from('evolucao_registros')
      .select('*, profiles(nome)')
      .eq('cliente_id', clienteId)
      .order('data_registro', { ascending: false })
    setRegistros(data || [])
  }

  function selecionarAntes(f: File) {
    setFileAntes(f)
    setPrevAntes(URL.createObjectURL(f))
  }

  function selecionarDepois(f: File) {
    setFileDepois(f)
    setPrevDepois(URL.createObjectURL(f))
  }

  async function uploadFoto(file: File, path: string): Promise<string> {
    const { error } = await supabase.storage.from('evolucao').upload(path, file, { upsert: true })
    if (error) throw error
    const { data: { publicUrl } } = supabase.storage.from('evolucao').getPublicUrl(path)
    return publicUrl
  }

  async function salvar() {
    if (!categoria) return
    setSalvando(true)
    try {
      const id = crypto.randomUUID()
      let urlAntes: string | null = null
      let urlDepois: string | null = null

      if (fileAntes) {
        const ext = fileAntes.name.split('.').pop()
        urlAntes = await uploadFoto(fileAntes, `${profile!.salao_id}/${clienteId}/${id}_antes.${ext}`)
      }
      if (fileDepois) {
        const ext = fileDepois.name.split('.').pop()
        urlDepois = await uploadFoto(fileDepois, `${profile!.salao_id}/${clienteId}/${id}_depois.${ext}`)
      }

      await supabase.from('evolucao_registros').insert({
        id,
        salao_id: profile!.salao_id,
        cliente_id: clienteId,
        profissional_id: profile!.id,
        categoria,
        subcategoria: subcategoria || null,
        servico_nome: servicoNome || null,
        foto_antes: urlAntes,
        foto_depois: urlDepois,
        observacoes: observacoes || null,
        visivel_cliente: true,
      })

      setModal(false)
      setFileAntes(null); setFileDepois(null)
      setPrevAntes(null); setPrevDepois(null)
      setSubcategoria(''); setServicoNome(''); setObservacoes('')
      await carregarRegistros()
    } catch (e) {
      alert('Erro ao salvar. Tente novamente.')
    }
    setSalvando(false)
  }

  async function toggleVisibilidade(id: string, atual: boolean) {
    await supabase.from('evolucao_registros').update({ visivel_cliente: !atual }).eq('id', id)
    await carregarRegistros()
  }

  async function excluir(id: string) {
    await supabase.from('evolucao_registros').delete().eq('id', id)
    await carregarRegistros()
  }

  const cor = salao?.cor_primaria || '#E91E8C'
  const categoriasFiltro = ['Todos', ...Object.keys(CATEGORIAS)]
  const registrosFiltrados = filtroCategoria === 'Todos'
    ? registros
    : registros.filter(r => r.categoria === filtroCategoria)

  if (loading) return (
    <div className="min-h-screen flex items-center justify-center">
      <div className="w-8 h-8 border-4 border-t-transparent rounded-full animate-spin" style={{ borderColor: cor }} />
    </div>
  )

  return (
    <div className="min-h-screen bg-[#f8f9fa] pb-10">
      <div className="bg-white px-4 py-4 flex items-center gap-3 shadow-sm sticky top-0 z-10">
        <button onClick={() => router.back()}><ArrowLeft size={22} className="text-gray-700" /></button>
        <div className="flex-1">
          <h1 className="font-bold text-gray-900 text-base">Evolução</h1>
          <p className="text-xs text-gray-400">{cliente?.nome}</p>
        </div>
        <button onClick={() => setModal(true)}
          className="flex items-center gap-1.5 px-4 py-2 rounded-full text-white text-sm font-medium"
          style={{ backgroundColor: cor }}>
          <Plus size={15} />Registrar
        </button>
      </div>

      <div className="px-4 py-4 flex flex-col gap-4">
        {/* Filtro categorias */}
        <div className="flex gap-2 overflow-x-auto pb-1 -mx-4 px-4">
          {categoriasFiltro.map(c => (
            <button key={c} onClick={() => setFiltroCategoria(c)}
              className="px-3 py-1.5 rounded-full text-xs font-medium whitespace-nowrap shrink-0 transition-all"
              style={filtroCategoria === c
                ? { backgroundColor: cor, color: 'white' }
                : { backgroundColor: 'white', color: '#6b7280' }}>
              {c}
            </button>
          ))}
        </div>

        {registrosFiltrados.length === 0 ? (
          <div className="card text-center py-12">
            <Camera size={36} className="text-gray-200 mx-auto mb-2" />
            <p className="text-gray-400 text-sm">Nenhum registro ainda</p>
            <p className="text-xs text-gray-300 mt-1">Registre a evolução após cada atendimento</p>
          </div>
        ) : registrosFiltrados.map(r => (
          <div key={r.id} className="bg-white rounded-2xl overflow-hidden shadow-sm">
            {/* Fotos */}
            {(r.foto_antes || r.foto_depois) && (
              <div className="grid grid-cols-2 gap-0.5">
                {r.foto_antes
                  ? <div className="relative">
                      <img src={r.foto_antes} alt="Antes" className="w-full h-40 object-cover" />
                      <span className="absolute bottom-2 left-2 text-xs bg-black/50 text-white px-2 py-0.5 rounded-full">Antes</span>
                    </div>
                  : <div className="h-40 bg-gray-50 flex items-center justify-center">
                      <span className="text-xs text-gray-300">Sem foto antes</span>
                    </div>}
                {r.foto_depois
                  ? <div className="relative">
                      <img src={r.foto_depois} alt="Depois" className="w-full h-40 object-cover" />
                      <span className="absolute bottom-2 left-2 text-xs bg-black/50 text-white px-2 py-0.5 rounded-full">Depois</span>
                    </div>
                  : <div className="h-40 bg-gray-50 flex items-center justify-center">
                      <span className="text-xs text-gray-300">Sem foto depois</span>
                    </div>}
              </div>
            )}

            <div className="p-4 flex flex-col gap-2">
              <div className="flex items-start justify-between">
                <div>
                  <div className="flex items-center gap-2 flex-wrap">
                    <span className="text-xs font-bold px-2 py-0.5 rounded-full text-white"
                      style={{ backgroundColor: cor }}>{r.categoria}</span>
                    {r.subcategoria && (
                      <span className="text-xs text-gray-500">{r.subcategoria}</span>
                    )}
                  </div>
                  {r.servico_nome && <p className="text-sm text-gray-700 mt-1">{r.servico_nome}</p>}
                  {r.observacoes && <p className="text-xs text-gray-400 mt-0.5">{r.observacoes}</p>}
                  <p className="text-xs text-gray-300 mt-1">
                    {new Date(r.data_registro).toLocaleDateString('pt-BR', {
                      day: '2-digit', month: 'long', year: 'numeric'
                    })} · {r.profiles?.nome}
                  </p>
                </div>
                <div className="flex items-center gap-1.5 shrink-0 ml-2">
                  <button onClick={() => toggleVisibilidade(r.id, r.visivel_cliente)}
                    className="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center"
                    title={r.visivel_cliente ? 'Ocultar da cliente' : 'Mostrar para cliente'}>
                    {r.visivel_cliente
                      ? <Eye size={14} className="text-gray-500" />
                      : <EyeOff size={14} className="text-gray-400" />}
                  </button>
                  <button onClick={() => excluir(r.id)}
                    className="w-8 h-8 rounded-full bg-red-50 flex items-center justify-center">
                    <Trash2 size={14} className="text-red-400" />
                  </button>
                </div>
              </div>
              {!r.visivel_cliente && (
                <p className="text-xs text-gray-300 italic">Oculto para a cliente</p>
              )}
            </div>
          </div>
        ))}
      </div>

      {/* Modal novo registro */}
      {modal && (
        <div className="fixed inset-0 bg-black/50 z-50 flex items-end">
          <div className="bg-white w-full rounded-t-3xl p-6 flex flex-col gap-4 max-h-[92vh] overflow-y-auto">
            <h3 className="font-bold text-gray-900 text-lg">Novo Registro de Evolução</h3>

            {/* Categoria */}
            <div>
              <label className="text-sm font-medium text-gray-700 mb-1 block">Categoria</label>
              <div className="flex gap-2 flex-wrap">
                {Object.keys(CATEGORIAS).map(c => (
                  <button key={c} onClick={() => { setCategoria(c); setSubcategoria('') }}
                    className="px-3 py-1.5 rounded-full text-sm font-medium transition-all"
                    style={categoria === c
                      ? { backgroundColor: cor, color: 'white' }
                      : { backgroundColor: '#f3f4f6', color: '#6b7280' }}>
                    {c}
                  </button>
                ))}
              </div>
            </div>

            {/* Subcategoria */}
            <div>
              <label className="text-sm font-medium text-gray-700 mb-1 block">Subcategoria</label>
              <select className="input-field" value={subcategoria} onChange={e => setSubcategoria(e.target.value)}>
                <option value="">Selecionar...</option>
                {(CATEGORIAS[categoria] || []).map(s => (
                  <option key={s} value={s}>{s}</option>
                ))}
              </select>
            </div>

            {/* Serviço realizado */}
            <div>
              <label className="text-sm font-medium text-gray-700 mb-1 block">Serviço realizado (opcional)</label>
              <input className="input-field" placeholder="Ex: Limpeza de pele + hidratação"
                value={servicoNome} onChange={e => setServicoNome(e.target.value)} />
            </div>

            {/* Fotos */}
            <div className="grid grid-cols-2 gap-3">
              <FotoUpload label="Foto Antes" preview={prevAntes} onChange={selecionarAntes} cor={cor} />
              <FotoUpload label="Foto Depois" preview={prevDepois} onChange={selecionarDepois} cor={cor} />
            </div>

            {/* Observações */}
            <div>
              <label className="text-sm font-medium text-gray-700 mb-1 block">Observações (opcional)</label>
              <textarea className="input-field resize-none" rows={3}
                placeholder="Anotações sobre o procedimento, reações, próximos passos..."
                value={observacoes} onChange={e => setObservacoes(e.target.value)} />
            </div>

            <div className="flex gap-3">
              <button onClick={() => setModal(false)}
                className="flex-1 py-3 rounded-2xl border border-gray-200 text-gray-600 font-medium">
                Cancelar
              </button>
              <button onClick={salvar} disabled={salvando}
                className="flex-1 py-3 rounded-2xl text-white font-medium disabled:opacity-50"
                style={{ backgroundColor: cor }}>
                {salvando ? 'Salvando...' : 'Salvar'}
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
